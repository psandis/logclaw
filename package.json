{
  "name": "logclaw",
  "version": "0.1.3",
  "description": "A Node-native log investigator: eats messy unstructured app output, groups stack traces, collapses repeats, and summarizes what went wrong with AI.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/psandis/logclaw.git"
  },
  "homepage": "https://github.com/psandis/logclaw#readme",
  "bugs": {
    "url": "https://github.com/psandis/logclaw/issues"
  },
  "type": "module",
  "bin": {
    "logclaw": "bin/logclaw.js",
    "lclaw": "bin/lclaw.js"
  },
  "files": [
    "bin",
    "dist",
    "data"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "log",
    "logs",
    "cli",
    "log-viewer",
    "log-parser",
    "claw"
  ],
  "author": "Petri",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.8"
  }
}
